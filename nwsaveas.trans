a":[["EV001",""],["Text",""],["lorem ipsum dolor sit amet",""],["Line 1\nLine 2\nLine 3",""],["EV002",""],["Actor 1",""],["Hello world",""],["Actor 2",""],["Howdy",""],["EV003",""],["EV004",""],["Johny",""],["Hello, how are you doing?",""]],"context":[["Map001/events/1/name"],["Map001/events/1/pages/0/list/0/message/hasPicture/bottom"],["Map001/events/1/pages/0/list/2/MZ Plugin Command/TextPicture/set/text"],["Map001/events/1/pages/0/list/5/MZ Plugin Command/TextPicture/set/text","Map001/events/3/pages/0/list/0/comment"],["Map001/events/2/name"],["Map001/events/2/pages/0/list/0/Show Text Attributes/actorName"],["Map001/events/2/pages/0/list/0/message/noPicture/bottom"],["Map001/events/2/pages/0/list/2/Show Text Attributes/actorName"],["Map001/events/2/pages/0/list/2/message/noPicture/bottom"],["Map001/events/3/name"],["Map001/events/4/name"],["Map001/events/4/pages/0/list/0/Show Text Attributes/actorName"],["Map001/events/4/pages/0/list/0/message/hasPicture/bottom"]],"tags":[null,null,null,["blue"]],"parameters":[null,[{"headerIndex":0,"headerParam":["Actor1",0,0,2,""]}],null,[{"headerIndex":0,"headerParam":["Line 1"]}],null,null,[{"headerIndex":0,"headerParam":["",0,0,2,"Actor 1"],"rowInfoText":"Actor 1"}],null,[{"headerIndex":2,"headerParam":["",0,0,2,"Actor 2"],"rowInfoText":"Actor 2"}],null,null,null,[{"headerIndex":0,"headerParam":["Actor1",0,0,2,"Johny"],"rowInfoText":"Johny"}]],"indexIds":{"EV001":0,"Text":1,"lorem ipsum dolor sit amet":2,"Line 1\nLine 2\nLine 3":3,"EV002":4,"Actor 1":5,"Hello world":6,"Actor 2":7,"Howdy":8,"EV003":9,"EV004":10,"Johny":11,"Hello, how are you doing?":12},"extension":"json","dataType":"map","filename":"Map001","basename":"Map001.json","path":"data/Map001.json","relPath":"data/Map001.json","dirname":"/data","originalFormat":"RPG MAKER MV RAW DATA","lineBreak":"\n","type":"","indexIsBuilt":false,"progress":{"translated":0,"length":13,"percent":0}},"data/Map008.json":{"data":[["EV001",""],["EV002",""],["Stephanie",""],["¡Meadow! ¿Por qué has tardado tanto?",""],["Ven, preséntate a tu nueva familia.",""],["Meadow",""],["Umm... \\. Hola... \\.Soy Meadow... \\.Meadow Springful.",""],["Father Ferdinand",""],["Es un placer conocerte al fin, Hija mía.",""],["Soy el Padre Ferdinand Malroy, fundador de este Monasterio.",""],["Nos alegra darte la bienvenida.",""],["Mother Miriam",""],["Soy la Madre Miriam Venecia... \\.Madre Superiora de este\nMonasterio.",""],["Aquí aprenderás sobre el Señor Jesucristo y su misericordia.",""],["Viktor",""],["Y yo soy el Hermano Viktor Cade... \\.Soy el Sacristán que\nsirve al Señor junto al Padre Ferdinand.",""],["Puedo mostrarte el Monasterio después de que hayamos\nterminado de presentarte al resto de la familia.",""],["Encantada de conoceros.",""],["¿Te gusta este sitio, Meadow?",""],["¡S-\\.Sí!",""],["Bien, me alegra escuchar eso. ",""],["¡Este será tu nuevo hogar!",""],["Muchas gracias por tomar a Meadow bajo su cuidado, Padre\nFerdinand.",""],["Y gracias también a ti, Madre Superiora. Hermano Viktor.",""],["Es la voluntad de Dios que aquellos que estén perdidos\npuedan encontrar aquí su refugio.",""],["Sí, cuidaremos bien de Meadow.",""],["Supongo que entonces esto es una despedida, Meadow.",""],["Si me necesitas, avisa al Padre Ferdinand o a la Madre\nSuperiora. Ellos se pondrán en contacto conmigo.",""],["Vale... \\.Doctora Stephanie... \\.Gracias.",""],["EV003",""],["EV004",""],["<stepSound>",""],["Brother Viktor",""],["EV009",""],["EV016",""],["EV017",""],["EV018",""],["EV019",""],["EV020",""],["EV021",""],["EV022",""],["EV023",""]],"context":[["Map008/events/1/name"],["Map008/events/2/name"],["Map008/events/2/pages/0/list/13/Show Text Attributes/actorName","Map008/events/2/pages/0/list/17/Show Text Attributes/actorName","Map008/events/2/pages/0/list/53/Show Text Attributes/actorName","Map008/events/2/pages/0/list/58/Show Text Attributes/actorName","Map008/events/2/pages/0/list/60/Show Text Attributes/actorName","Map008/events/2/pages/0/list/68/Show Text A