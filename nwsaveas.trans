ttom"],["Map008/events/2/pages/0/list/60/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/68/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/71/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/74/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/77/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/82/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/84/message/hasPicture/bottom"],["Map008/events/2/pages/0/list/87/message/hasPicture/bottom"],["Map008/events/3/name"],["Map008/events/4/name"],["Map008/events/5/note","Map008/events/6/note","Map008/events/7/note","Map008/events/8/note"],["Map008/events/7/name"],["Map008/events/9/name"],["Map008/events/16/name"],["Map008/events/17/name"],["Map008/events/18/name"],["Map008/events/19/name"],["Map008/events/20/name"],["Map008/events/21/name"],["Map008/events/22/name"],["Map008/events/23/name"]],"tags":[],"parameters":[null,null,null,[{"headerIndex":13,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":17,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],null,[{"headerIndex":24,"headerParam":["SF_Actor3",7,0,2,"Meadow"],"rowInfoText":"Meadow"}],null,[{"headerIndex":27,"headerParam":["People3",4,0,2,"Father Ferdinand"],"rowInfoText":"Father Ferdinand"}],[{"headerIndex":29,"headerParam":["People3",4,0,2,"Father Ferdinand"],"rowInfoText":"Father Ferdinand"}],[{"headerIndex":31,"headerParam":["People3",4,0,2,"Father Ferdinand"],"rowInfoText":"Father Ferdinand"}],null,[{"headerIndex":34,"headerParam":["SF_People1",7,0,2,"Mother Miriam"],"rowInfoText":"Mother Miriam"}],[{"headerIndex":37,"headerParam":["SF_People1",7,0,2,"Mother Miriam"],"rowInfoText":"Mother Miriam"}],null,[{"headerIndex":40,"headerParam":["SF_Actor1",6,0,2,"Viktor"],"rowInfoText":"Viktor"}],[{"headerIndex":43,"headerParam":["SF_Actor1",6,0,2,"Viktor"],"rowInfoText":"Viktor"}],[{"headerIndex":47,"headerParam":["SF_Actor3",7,0,2,"Meadow"],"rowInfoText":"Meadow"}],[{"headerIndex":53,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":55,"headerParam":["SF_Actor3",7,0,2,"Meadow"],"rowInfoText":"Meadow"}],[{"headerIndex":58,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":60,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":68,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":71,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":74,"headerParam":["People3",4,0,2,"Father Ferdinand"],"rowInfoText":"Father Ferdinand"}],[{"headerIndex":77,"headerParam":["SF_People1",7,0,2,"Mother Miriam"],"rowInfoText":"Mother Miriam"}],[{"headerIndex":82,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":84,"headerParam":["SF_Actor3",1,0,2,"Stephanie"],"rowInfoText":"Stephanie"}],[{"headerIndex":87,"headerParam":["SF_Actor3",7,0,2,"Meadow"],"rowInfoText":"Meadow"}]],"indexIds":{"EV001":0,"EV002":1,"Stephanie":2,"¡Meadow! ¿Por qué has tardado tanto?":3,"Ven, preséntate a tu nueva familia.":4,"Meadow":5,"Umm... \\. Hola... \\.Soy Meadow... \\.Meadow Springful.":6,"Father Ferdinand":7,"Es un placer conocerte al fin, Hija mía.":8,"Soy el Padre Ferdinand Malroy, fundador de este Monasterio.":9,"Nos alegra darte la bienvenida.":10,"Mother Miriam":11,"Soy la Madre Miriam Venecia... \\.Madre Superiora de este\nMonasterio.":12,"Aquí aprenderás sobre el Señor Jesucristo y su misericordia.":13,"Viktor":14,"Y yo soy el Hermano Viktor Cade... \\.Soy el Sacristán que\nsirve al Señor junto al Padre Ferdinand.":15,"Puedo mostrarte el Monasterio después de que hayamos\nterminado de presentarte al resto de la familia.":16,"Encantada de conoceros.":17,"¿Te gusta este sitio, Meadow?":18,"¡S-\\.Sí!":19,"Bien, me alegra escuchar eso. ":20,"¡Este será tu nuevo hogar!":21,"Muchas gracias por tomar a Meadow bajo su cuidado, Padre\nFerdinand.":22,"Y gracias también a ti, Madre Superiora. Hermano Viktor.":23,"Es la voluntad de Dios que aquellos que estén perdidos\npuedan encontrar aquí su refugio.":24,"Sí, cuidaremos bien de Meadow.":25,"Supongo que entonces esto es una despedida, Meadow.":26,"Si me necesitas, avisa al Padre Ferdinand o a la Madre\nSuperiora. Ellos se pondrán en contacto conmigo.":27,"Vale... \\.Doctora Stephanie... \\.Gracias.":28,"EV003":29,"EV004":30,"<stepSound>":31,"Brother Viktor":32,"EV009":33,"EV016":34,"EV017":35,"EV018":36,"EV019":37,"EV020":38,"EV021":39,"EV022":40,"EV023":41},"extension":"json","dataType":"map","filename":"Map008","basename":"Map008.json","path":"data/Map008.json","relPath":"data/Map008.json","dirname":"/data","originalFormat":"RPG MAKER MV RAW DATA","lineBreak":"\n","type":"","indexIsBuilt":false,"progress":{"translated":0,"length":42,"percent":0}},"data/MapInfos.json":{"data":[["MAP001",""]],"context":[["MapInfos/1/name"]],"tags":[],"parameters":[],"indexIds":{"MAP001":0},"extension":"json","dataType":"mapinfos","filename":"MapInfos","basename":"MapInfos.json","path":"data/MapInfos.json","relPath":"data/MapInfos.json","dirname":"/data","originalFormat":"RPG MAKER MV RAW DATA","lineBreak":"\n","type":"","indexIsBuilt":false,"progress":{"translated":0,"length":1,"percent":0}},"data/Skills.json":{"data":[["Attack",""],["%1 attacks!",""],["Skill #1 corresponds to the Attack command.",""],["Guard",""],["%1 guards.",""],["Skill #2 corresponds to the Guard command.",""],["-----Reserved",""],["Below are spaces for when you would like to display\nthings above skills when you open the menu.",""],["-----Enemy",""],["Dual Attack",""],["Performs a series of attacks on an enemy.",""],["Double Attack",""],["Performs a double attack on a random enemy.",""],["Triple Attack",""],["Performs a triple attack on a random enemy.",""],["Escape",""],["The user flees from battle.",""],["%1 flees.",""],["Wait and See",""],["Waits to see what happens.",""],["%1 is 