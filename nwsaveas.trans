ies with low HP for 1 turn.",""],["%1 protects team.",""],["Falcon Thrust",""],["Performs an attack on an enemy faster than anyone\nelse.",""],["Double Thrust",""],["Armor Piercer",""],["Battle Cry",""],["%1 made a battle cry!",""],["Windmill",""],["Clear Mind",""],["Slightly increases the user’s TP.",""],["%1 cleared their mind!",""],["Wild Thrust",""],["Randomly performs 4 attacks on 4 enemies.",""],["-----Bandit Skills",""],["Warm-up",""],["Increases the user’s Agility.",""],["%1 started %2!",""],["Flare",""],["Watchful Eye",""],["Increases items and money gained from battle for\na while.",""],["%1 is observing their surroundings carefully.",""],["Wind Call",""],["Hide",""],["Makes the user harder to target.",""],["%1 hid.",""],["-----Martial Artist Skills",""],["Sweep",""],["Inflicts damage and causes all enemies to lose balance.",""],["Qigong",""],["Cures the user from being weakened.",""],["Roundhouse Kick",""],["Inflicts huge damage on all enemies.",""],["Tiger Dance",""],["-----Hunter Skills",""],["Point Shot",""],["Decreases an enemy’s Attack and Defense.",""],["Stun Shot",""],["Shoots at the footing of all enemies and causes them\nto lose balance.",""],["Team Shot",""],["Inflicts damage on an enemy 5 times.",""],["Rain Shot",""],["Inflicts damage on all enemies 2 times.",""]],"context":[["Skills/1/name"],["Skills/1/message1","Skills/12/message1","Skills/13/message1","Skills/14/message1","Skills/41/message1"],["Skills/1/note"],["Skills/2/name"],["Skills/2/message1"],["Skills/2/note"],["Skills/3/name"],["Skills/3/description"],["Skills/11/name"],["Skills/12/name","Skills/174/name"],["Skills/12/description"],["Skills/13/name"],["Skills/13/description"],["Skills/14/name"],["Skills/14/description"],["Skills/15/name"],["Skills/15/description"],["Skills/15/message1"],["Skills/16/name"],["Skills/16/description"],["Skills/16/message1"],["Skills/17/name"],["Skills/17/description","Skills/91/description"],["Skills/17/message1"],["Skills/18/name"],["Skills/18/descript