,""],["[Light Equipment] A hat made of tanned hide.",""],["Wooden Cap",""],["[Light Equipment] A light helmet made of wood.",""],["Bronze Cap",""],["[Light Equipment] A light helmet reinforced with\nbronze plates.",""],["Iron Cap",""],["[Light Equipment] A light helmet reinforced with\niron plates.",""],["Mithril Cap",""],["[Light Equipment] A light helmet reinforced with\nmithril.",""],["Dragon Cap",""],["[Light Equipment] A light helmet reinforced with\ndragon scales.",""],["Chainmail Coif",""],["[Heavy Equipment] A hood made with fine, woven chains.",""],["Bronze Helm",""],["[Heavy Equipment] A helmet made with thick bronze\nplates.",""],["Iron Helm",""],["[Heavy Equipment] A helmet made with thick iron\nplates.",""],["Mithril Helm",""],["[Heavy Equipment] A helmet made of mithril.",""],["Dragon Helm",""],["[Heavy Equipment] A helmet made with dragon scales.",""],["Pointed Hat",""],["[Magic Equipment] A triangular, tanned hide hat with\na wide brim.",""],["Circlet",""],["[Magic Equipment] A simple crown enchanted with\nprotective magic.",""],["Silver Circlet",""],["[Magic Equipment] A silver crown enchanted with\nprotective magic.",""],["Gold Circlet",""],["[Magic Equipment] A pure gold crown enchanted with\nprotective magic.",""],["Mithril Circlet",""],["[Magic Equipment] A mithril crown enchanted with\nprotective magic.",""],["Master Circlet",""],["[Magic Equipment] A sage’s crown enchanted with\nprotective magic.",""],["-----Accessories",""],["Guard Stone",""],["[Accessory] A charm that increases Defense.",""],["Guard Ring",""],["[Accessory] A ring that increases Defense.",""],["Power Stone",""],["[Accessory] A charm that increases Attack.",""],["Power Ring",""],["[Accessory] A ring that increases Attack.",""],["Speed Stone",""],["[Accessory] A charm that increases Agility.",""],["Speed Ring",""],["[Accessory] A ring that increases Agility.",""],["Lucky Stone",""],["[Accessory] A charm that increases Luck.",""],["Lucky Ring",""],["[Accessory] A ring that incre